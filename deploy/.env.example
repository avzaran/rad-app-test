# Docker Compose environment for deploy/docker-compose.yml
# Copy this file to deploy/.env and fill in secrets locally.
# Do not commit deploy/.env.

# AI Gateway provider selection
PROVIDER_MODE=mock

# OpenAI / OpenRouter (PROVIDER_MODE=openai)
LLM_BASE_URL=https://openrouter.ai/api
LLM_API_KEY=
LLM_MODEL=google/gemini-2.0-flash
LLM_COMPLETIONS_PATH=/v1/chat/completions

# DeepSeek (PROVIDER_MODE=deepseek)
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Gemini (PROVIDER_MODE=gemini)
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
