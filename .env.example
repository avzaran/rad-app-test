# Root environment template

# Frontend
VITE_API_BASE_URL=http://localhost:8080
VITE_USE_MOCK_API=true
VITE_AI_ENABLED=true

# Backend
PORT=8080
JWT_SECRET=dev-secret-change-me
ACCESS_TTL_MINUTES=15
REFRESH_TTL_HOURS=168
RATE_LIMIT_PER_MIN=240
STORAGE_BASE_URL=http://localhost:9000
STORAGE_BUCKET_NAME=radassist-files

# Backend -> AI Gateway
AI_GATEWAY_URL=http://localhost:8090

# AI Gateway
AI_GATEWAY_PORT=8090
REQUEST_TIMEOUT_MS=5000
RETRY_COUNT=2
RETRY_BACKOFF_MS=250
CIRCUIT_THRESHOLD=5
CIRCUIT_COOLDOWN_S=30

# Provider: "mock", "openai", "deepseek", or "gemini"
# For OpenRouter: use PROVIDER_MODE=openai with LLM_BASE_URL=https://openrouter.ai/api
PROVIDER_MODE=openai

# OpenAI / OpenRouter (PROVIDER_MODE=openai)
# OpenRouter gives access to all models via single key: https://openrouter.ai
LLM_BASE_URL=https://openrouter.ai/api
LLM_API_KEY=
LLM_MODEL=google/gemini-2.0-flash

# DeepSeek (PROVIDER_MODE=deepseek)
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Gemini (PROVIDER_MODE=gemini)
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
